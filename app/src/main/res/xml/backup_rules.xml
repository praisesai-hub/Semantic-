<?xml version="1.0" encoding="utf-8"?>
<!--
  allowBackup is false at the manifest level (primary control).
  These rules are defense-in-depth in case that flag is ever changed —
  the encrypted vault and database must never leave the device via backup.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="file" path="vault/" />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
